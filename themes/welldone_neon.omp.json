{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} ┬À {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "¯éÂ",
          "trailing_diamond": "¯é░",
          "foreground": "#0d0b14",
          "background": "#ff00c8",
          "template": " ¯ÿ¬ "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "#00eaff",
          "background": "#1a1030",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3
          },
          "template": " ´ü╝ {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "#0aff9d",
          "background": "#0d1a14",
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " ¯éá {{ .HEAD }}{{ if .Working.Changed }} ´üä {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} ´üå {{ .Staging.String }}{{ end }} "
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "#0aff9d",
          "background": "#0d1a0d",
          "template": " ¯£ÿ {{ .Full }} ",
          "properties": {
            "display_mode": "files"
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "overflow": "hidden",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#ffcc00",
          "template": "{{ if gt .Ms 1000 }}´ëÆ {{ .FormattedMs }} {{ end }}"
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "#ff00c8",
          "template": "´Çù {{ .CurrentDate | date \"15:04\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#ff00c8",
          "template": "ÔØ» "
        }
      ]
    }
  ],
  "secondary_prompt": {
    "foreground": "#a000ff",
    "template": "ÔØ»ÔØ» "
  },
  "transient_prompt": {
    "foreground": "#ff00c8",
    "template": "ÔØ» "
  }
}
